{
  "name": "eureka-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pigi:recon": "tsx scripts/pigi/recon.ts",
    "pigi:extract": "node --experimental-strip-types --no-warnings scripts/pigi/run.ts",
    "pigi:derive": "node --experimental-strip-types --no-warnings scripts/pigi/derive-signals.ts",
    "pigi": "npm run pigi:extract && npm run pigi:derive",
    "pigi:watch": "node --experimental-strip-types --no-warnings scripts/pigi/run.ts --watch",
    "pigi:import-saved-searches": "node --experimental-strip-types --no-warnings scripts/pigi/import-saved-searches.ts",
    "pigi:install-schedule": "bash scripts/pigi/install-schedule.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4",
    "typescript": "^5"
  }
}
